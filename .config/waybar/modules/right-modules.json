{
    "tray": {
        "icon-size": 14,
        "spacing": 2
    },
    "wireplumber#source": {
        "node-type": "Audio/Source",
        "format": "{volume}% ≤░Ξυ",
        "format-muted": "≤░Ξφ",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "scroll-step": 5
    },
    "wireplumber": {
        "format": "{volume}% {icon} {format_source}",
        "format-muted": " {format_source}",
        "format-source": "{source_volume}% ",
        "format-source-muted": " ",
        "format-icons": {
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        }
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["≤░╣Ρ", "≤▒σΡ", "≤▒σΥ", "≤▒σΨ", "≤░δρ"]
    },
    "network": {
        "format": "{essid} {signalStrength}%"
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "clock": {
        "format-alt": "{:%a, %d. %b  %H:%M}"
    },
    "custom/power": {
		"format": "≤░νΕ",
		"on-click": "wezterm -e ~/.config/waybar/scripts/power",
		"tooltip-format": "Power Menu"
	}
}